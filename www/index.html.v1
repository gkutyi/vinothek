<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Vinothek</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

<h1>🍷 Vinothek</h1>

<button onclick="scanQR()">QR Scannen</button>
<button onclick="exportBackup()">Backup</button>

<h2>Neuer Wein</h2>

<input id="name" placeholder="Name">
<input id="jahrgang" placeholder="Jahrgang">
<input id="region" placeholder="Region">
<input id="lagerort" placeholder="Lagerort">
<input id="platz" placeholder="Platz">
<input id="anzahl" placeholder="Anzahl" type="number">
<input id="notizen" placeholder="Notizen">

<button onclick="saveWine()">Speichern</button>

<h2>Bestand</h2>

<table id="weinTable">
    <thead>
        <tr>
            <th>Name</th>
            <th>Jahr</th>
            <th>Region</th>
            <th>Lager</th>
            <th>Platz</th>
            <th>Anzahl</th>
            <th>QR</th>
        </tr>
    </thead>
    <tbody></tbody>
</table>

<script src="app.js"></script>

</body>
</html>
